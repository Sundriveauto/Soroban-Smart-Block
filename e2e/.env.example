# E2E Test Configuration

# ── API Endpoints ────────────────────────────────────────────────────────
INDEXER_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://soroban:soroban_secret@localhost:5432/soroban_explorer

# ── Stellar Network ──────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
CONTRACT_ID=

# ── k6 Load Testing ──────────────────────────────────────────────────────
# Baseline test: 100 req/s for 5 minutes (default)
# Spike test: 0-2000 req/s in 10 seconds
# Soak test: 200 req/s for 4 hours
K6_RESULTS_DIR=./k6-results

# ── Synthetic Monitoring ────────────────────────────────────────────────
# Submits synthetic events to testnet/mainnet and verifies they appear
# within SLA (30 seconds)
ITERATIONS=5
SLA_SECONDS=30

# ── Playwright ───────────────────────────────────────────────────────────
# Browsers to test: chromium, firefox, webkit, mobile
# Screenshots/videos on failure
PLAYWRIGHT_VIDEO=retain-on-failure
PLAYWRIGHT_SCREENSHOT=only-on-failure

# ── Percy Visual Regression ─────────────────────────────────────────────
# Set PERCY_TOKEN to enable visual regression tests
# Get token from https://percy.io
PERCY_TOKEN=
PERCY_PARALLEL_NONCE=
PERCY_PARALLEL_TOTAL=

# ── CI/CD ────────────────────────────────────────────────────────────────
CI=false
HEADLESS=true
