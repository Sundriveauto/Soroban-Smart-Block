#!/usr/bin/env sh
# Runs before every `git push`. Keeps broken contract code off the remote.
# To skip in an emergency: git push --no-verify

set -e

echo "» pre-push: building contracts (wasm32)…"
cargo build --target wasm32-unknown-unknown --release -p soroban-explorer-contract

echo "» pre-push: running explorer contract tests…"
cargo test -p soroban-explorer-contract

echo "» pre-push: running ticket contract tests…"
(cd contracts/ticket && cargo test --features testutils --release)

echo "» pre-push: all checks passed ✓"
