{
  "name": "Soroban Smart Block Explorer",
  "image": "mcr.microsoft.com/devcontainers/rust:1",
  "forwardPorts": [5173, 3001, 5432],
  "portsAttributes": {
    "5173": {
      "label": "Frontend",
      "onAutoForward": "openPreview"
    },
    "3001": {
      "label": "Indexer API",
      "onAutoForward": "silent"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "rust-lang.rust-analyzer",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "postCreateCommand": "echo 'Skipping automated setup in devcontainer; run npm install and cargo fetch manually if needed.'",
  "postStartCommand": "echo 'Container started. Run `npm run setup -- --non-interactive` if required.'"
}
