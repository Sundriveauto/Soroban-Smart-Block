{
  "name": "Soroban Smart Block Explorer",

  // Build the dev image from .devcontainer/Dockerfile (Rust + Node 20 + wasm32)
  // and compose up postgres as a sidecar. Uses a self-contained compose file so
  // Codespaces doesn't attempt to build the full production stack on startup.
  "dockerComposeFile": "docker-compose.devcontainer.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/Soroban-Smart-Block",
  "overrideCommand": true,

  "forwardPorts": [5173, 3001, 5432],
  "portsAttributes": {
    "5173": { "label": "Frontend", "onAutoForward": "openPreview" },
    "3001": { "label": "Indexer API", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "rust-lang.rust-analyzer",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[rust]": { "editor.defaultFormatter": "rust-lang.rust-analyzer" }
      }
    }
  },

  "postCreateCommand": "cp -n .env.example .env 2>/dev/null || true && npm install && cd indexer && npm ci && cd ../frontend && npm ci && cd .. && cargo fetch",
  "postStartCommand": "echo '✅ Container ready. Run: make dev'"
}
